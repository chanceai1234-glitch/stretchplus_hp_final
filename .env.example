# === STRETCH+ 運用自動化システム 環境変数 ===
# このファイルをコピーして「.env」という名前にし、各種設定値を入力してください。

# 1. 宛先メールアドレスの設定（カンマ区切りで複数指定可能）
REPORT_TARGET_EMAILS=owner@stretch-plus.co.jp,manager@stretch-plus.co.jp

# 2. メールの送信元設定（XSERVERのメールアカウント等を利用）
SMTP_SERVER=sv****.xserver.jp
SMTP_PORT=465
SMTP_USER=info@stretch-plus.co.jp
SMTP_PASS=YOUR_EMAIL_PASSWORD
MAIL_FROM=info@stretch-plus.co.jp

# 3. Google Analytics 4 (GA4) の設定
# GA4の管理画面 ＞ プロパティ設定 ＞ プロパティ詳細 に記載されている「プロパティID」
GA4_PROPERTY_ID=123456789
# ダウンロードしたサービスアカウントキー（JSONファイル）のパス
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json

# 4. AI連携の設定（月次レポートの改善提案生成用）
# OpenAI APIキー を入力してください（空欄の場合はAI提案がスキップされます）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
